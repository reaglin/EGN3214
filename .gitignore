# PreseMaker — default .gitignore
# Generated by PreseMaker on first git init.
# Edit below or use the .gitignore editor in the Git / GitHub dialog.

# Generated audio (large files — regenerate from narration text)
output/audio/

# Generated slide images
output/images/

# Narrated PPTX files (~70 MB each — regenerated from source PPTX + audio)
*_narrated.pptx

# MP4 video files (400+ MB each — all MP4 files excluded; regenerate from narrated PPTX)
*.mp4

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini